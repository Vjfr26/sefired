# Producción — cambia VITE_API_URL por la URL real de tu backend.
# Ejemplo: VITE_API_URL=https://api.jandm.com
#
# Si el frontend y el backend comparten dominio (nginx con /api/* → backend),
# déjalo vacío igual que en desarrollo.
VITE_API_URL=

VITE_APP_NAME=J&M

# Cloudflare Turnstile — site key real (registrado para el dominio de producción)
VITE_TURNSTILE_SITE_KEY=0x4AAAAAADPWm4GmxJIO3s97
