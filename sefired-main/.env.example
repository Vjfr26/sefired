# ============================================================
#  .env.example — copia esto a .env y ajusta los valores.
#  Este archivo SÍ se sube al repositorio (sin secretos reales).
# ============================================================

# --- Base de datos -------------------------------------------
DB_ROOT_PASSWORD=secret
DB_NAME=jm
DB_PORT=3306

# --- Backend (Laravel) ---------------------------------------
BACKEND_PORT=8000
APP_KEY=                         # genera con: php artisan key:generate --show
APP_URL=http://localhost:8000

# CORS: orígenes permitidos para llamar a la API.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# Cloudflare Turnstile — claves reales del dashboard de Cloudflare.
# Site key (frontend):   VITE_TURNSTILE_SITE_KEY en FrontEnd_Clientes/.env.production y FrontEnd_Interno/.env.production
# Secret key (backend):  reemplaza el valor de abajo con tu clave secreta real.
TURNSTILE_SECRET_KEY=0x4AAAAAADPWmz0f7wTP0t91okM05GVSgwc

# --- FrontEnd Interno ----------------------------------------
FRONTEND_INTERNO_PORT=5173
VITE_API_URL_INTERNO=

# --- FrontEnd Clientes ---------------------------------------
FRONTEND_CLIENTES_PORT=5174
VITE_API_URL_CLIENTES=
